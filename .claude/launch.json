{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "ngw-dev",
      "runtimeExecutable": ".venv/bin/uvicorn",
      "runtimeArgs": ["main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000
    },
    {
      "name": "ngw-ui",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "ui"],
      "port": 5173,
      "autoPort": true
    }
  ]
}
