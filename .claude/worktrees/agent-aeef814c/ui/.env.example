# ── NGW Frontend Environment Variables ─────────────────────────────
#
# Copy this file to .env.local for local development.
# In production (Vercel), set these in the Vercel dashboard.
#
# IMPORTANT: All VITE_ variables are bundled into the frontend at build
# time. Never put secrets (API keys, JWT secrets) here.
# ────────────────────────────────────────────────────────────────────

# Backend API base URL.
#
# Development: leave empty — Vite proxy handles it (see vite.config.js)
# Production (Vercel → Render): set to your Render service URL
#
# Example: https://ngw-api.onrender.com
VITE_API_BASE_URL=
