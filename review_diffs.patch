+def _was_clamped(value: float, cap: float) -> str:
+    """Return a parenthetical note if the value was clamped, else ''."""
+    if value < 0:
+        return " (clamped from negative)"
+    if value > cap:
+        return f" (capped at {cap})"
+    return ""
+
