# Never send these to the Docker build context
.git
.gitignore
.env
.env.*
__pycache__
*.pyc
*.pyo
.pytest_cache

# Node — platform-native binaries installed by npm ci inside the container
# must not be overwritten by macOS-built node_modules from the host
ui/node_modules

# Vite dev artifacts
ui/.vite
ui/dist

# Python virtualenv
.venv
venv

# Runtime / user-generated data — excluded from image (lives on persistent disk)
# Static app data (data/taxonomy/, data/systems/, etc.) IS included — engine needs it.
data/uploads/
data/gold_set/
data/confusion_set/
data/intelligence_runs/
data/*.db
static/uploads/

# Docs / scripts (not needed at runtime)
docs/
scripts/
