# NGW Core v1 — Environment variables
# Copy to .env for local development. Never commit .env to git.

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT signing secret — REQUIRED in production. NEVER use the dev default in production.
# Generate with: openssl rand -hex 32
NGW_JWT_SECRET=REPLACE_WITH_SECRET_openssl_rand_hex_32

# Admin secret for waitlist endpoints — SEPARATE from the JWT key.
# Keeping them separate means a compromised JWT key doesn't expose admin endpoints.
# Generate with: openssl rand -hex 24
NGW_ADMIN_SECRET=REPLACE_WITH_ADMIN_SECRET_openssl_rand_hex_24

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# Logging — DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── VLM (Vision-Language Model) ───────────────────────────────────────────────
# Enriches reference photo analysis. Set VLM_PROVIDER=none to disable.
VLM_PROVIDER=openai
OPENAI_API_KEY=
# gpt-4o is outdated — use gpt-4o-mini for cost or gpt-4.1 / gpt-5.4 for best analysis quality
VLM_MODEL=gpt-4o

# ── API Key Rotation & Safety ─────────────────────────────────────────────────
# Production recommendations:
#   1. SPEND LIMITS: Set a monthly spend cap at platform.openai.com/settings/limits
#      to prevent runaway billing. Recommended: $50/month cap with email alerts.
#   2. ROTATION: Rotate keys every 90 days. Update OPENAI_API_KEY here and restart.
#      The server probes the key at startup and logs failures immediately.
#   3. SECRETS MANAGER: In production, use a secrets manager instead of .env:
#      - AWS: aws secretsmanager get-secret-value --secret-id ngw/openai-key
#      - GCP: gcloud secrets versions access latest --secret=openai-api-key
#      - Doppler: set DOPPLER_TOKEN and remove API keys from this file entirely
#   4. MONITORING: GET /api/health/api-keys shows key status + recent errors.
#      POST /api/health/api-keys/probe runs a live test (no token cost).
#   5. NEVER commit this file with real keys — .env is in .gitignore already.
#
# OPENAI_SPEND_LIMIT_MONTHLY_USD=50   # set on platform.openai.com, not here
# KEY_ROTATION_DAYS=90                # informational — set a calendar reminder

# ── Lab / Dev ─────────────────────────────────────────────────────────────────
# Comma-separated email addresses allowed to access NGW Lab features.
NGW_DEV_EMAILS=

# Set to 1 to bypass auth for Lab endpoints locally. Never enable in production.
NGW_DEV_MODE=

# ── Email (transactional) ──────────────────────────────────────────────────────
# Uses Resend SMTP relay — https://resend.com/docs/send-with-smtp
# Sign up at resend.com → API Keys → create key → paste as SMTP_PASS
# Verify your sending domain under Resend → Domains, then set FROM_EMAIL.
# Leave SMTP_HOST blank to skip sending and print links to server stdout (dev default).
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@noguessworksystems.com

# Base URL used in email links. Set to your production domain in production.
APP_URL=https://noguessworksystems.com

# ── Stripe ────────────────────────────────────────────────────────────────────
# Required for checkout and webhook handling. Get from dashboard.stripe.com.
# Use sk_test_... / pk_test_... for development, sk_live_... for production.
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY
STRIPE_PRICE_ID_MONTHLY=price_REPLACE_WITH_MONTHLY_PRICE_ID
STRIPE_PRICE_ID_YEARLY=price_REPLACE_WITH_YEARLY_PRICE_ID
# Webhook signing secret — from Stripe Dashboard → Webhooks → your endpoint → Signing secret.
# Required to validate that webhook events actually come from Stripe (not spoofed).
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_WEBHOOK_SIGNING_SECRET

# ── Environment ───────────────────────────────────────────────────────────────
# Set to "production" on Render/cloud. Defaults to "production" if unset.
# Set to "development" locally when using NGW_DEV_MODE.
ENVIRONMENT=development

# ── Observability ─────────────────────────────────────────────────────────────
# Sentry error tracking — get DSN from sentry.io → your project → Settings → DSN
# Leave blank to disable (server still starts, errors only go to logs).
SENTRY_DSN=

# ── Rate limiter (proxy trust) ─────────────────────────────────────────────────
# Set to 0 if NOT behind a reverse proxy — prevents IP spoofing via X-Forwarded-For.
# Leave at 1 (default) when behind Render, Cloudflare, or a verified load balancer.
TRUST_PROXY_HEADERS=1
# Optionally, comma-separate the exact IPs of your trusted proxies for stricter control.
# If set, X-Forwarded-For is only trusted when the direct socket IP matches this list.
# TRUSTED_PROXY_IPS=
