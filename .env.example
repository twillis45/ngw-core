# NGW Core v1 — Environment variables (all optional)

# Server
HOST=0.0.0.0
PORT=8000

# Logging — DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# VLM (Vision-Language Model) — enriches reference photo analysis with
# subject/expression/cosmetic details that pure CV cannot detect.
# Set VLM_PROVIDER=none to disable.
VLM_PROVIDER=openai
OPENAI_API_KEY=
VLM_MODEL=gpt-4o

# Lab access — comma-separated list of email addresses allowed to access NGW Lab.
# If empty or unset, Lab endpoints return 403 for all users.
NGW_DEV_EMAILS=

# Dev mode — set to 1 to bypass all auth for Lab endpoints.
# Useful for local testing. Never enable in production.
NGW_DEV_MODE=
