# NGW Core v1 — Environment variables
# Copy to .env for local development. Never commit .env to git.

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT signing secret — REQUIRED in production
# Generate with: openssl rand -hex 32
NGW_JWT_SECRET=ngw-dev-secret-change-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# Logging — DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── VLM (Vision-Language Model) ───────────────────────────────────────────────
# Enriches reference photo analysis. Set VLM_PROVIDER=none to disable.
VLM_PROVIDER=openai
OPENAI_API_KEY=
VLM_MODEL=gpt-4o

# ── Lab / Dev ─────────────────────────────────────────────────────────────────
# Comma-separated email addresses allowed to access NGW Lab features.
NGW_DEV_EMAILS=

# Set to 1 to bypass auth for Lab endpoints locally. Never enable in production.
NGW_DEV_MODE=
